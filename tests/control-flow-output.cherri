/* Control flow output */

@x = 5
const bigger = if @x > 3 {
    text("yes")
} else {
    text("no")
}
@biggerStr = "{bigger}"
if @biggerStr != "yes" {
    alert("❌ FAIL: if output (true branch) — got {@biggerStr}, expected 'yes'")
}

const smaller = if @x > 100 {
    text("yes")
} else {
    text("no")
}
@smallerStr = "{smaller}"
if @smallerStr != "no" {
    alert("❌ FAIL: if output (false branch) — got {@smallerStr}, expected 'no'")
}

// compile-only: device-dependent and interactive values
@deviceModel = "{Device['Model']}"
const connectionName = if @deviceModel == "iPhone" {
    getCellularDetail("Carrier Name")
} else {
    getWifiDetail("Network Name")
}
show("{connectionName}")

// repeat output: compile-only (output format varies)
const repeated = repeat i for 6 {
    number(@i)
}
show("{repeated}")

// for/in output: compile-only (output is a list)
@items = ["1", "2", "3"]
const mapped = for item in @items {
    number(@item)
}
show("{mapped}")

show("✅ All tests passed")
