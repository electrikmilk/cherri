@dict = {"name": "Alice", "score": 99, "active": true}

// getValue — no declared return type, so interpolate into a typed variable first
const name = getValue(@dict, "name")
@nameStr = "{name}"
if @nameStr != "Alice" {
    alert("❌ FAIL: getValue — got {@nameStr}, expected 'Alice'")
}

// bracket syntax shorthand
@nameAlt = @dict['name']
@nameAltStr = "{@nameAlt}"
if @nameAltStr != "Alice" {
    alert("❌ FAIL: dict['key'] — got {@nameAltStr}, expected 'Alice'")
}

// setValue round-trip — setValue returns :dictionary so getValue on its result is fine
const updated = setValue(@dict, "name", "Bob")
const newName = getValue(updated, "name")
@newNameStr = "{newName}"
if @newNameStr != "Bob" {
    alert("❌ FAIL: setValue — got {@newNameStr}, expected 'Bob'")
}

// getDictionary from raw JSON string — getDictionary returns :dictionary
@json = '{"key": "hello", "num": 7}'
const parsed = getDictionary(@json)
const parsedVal = getValue(parsed, "key")
@parsedValStr = "{parsedVal}"
if @parsedValStr != "hello" {
    alert("❌ FAIL: getDictionary/getValue — got {@parsedValStr}, expected 'hello'")
}

// getKeys returns :array (has value check works for any type)
const keys = getKeys(@dict)
if !keys {
    alert("❌ FAIL: getKeys — returned no value")
}

// getValues returns :array
const vals = getValues(@dict)
if !vals {
    alert("❌ FAIL: getValues — returned no value")
}

show("✅ All tests passed")
