@dict = {"name": "Alice", "score": 99, "active": true}

// getValue
const name = getValue(@dict, "name")
if name != "Alice" {
    alert("❌ FAIL: getValue — got {name}, expected 'Alice'")
}

// bracket syntax shorthand
@nameAlt = @dict['name']
@nameAltStr = "{@nameAlt}"
if @nameAltStr != "Alice" {
    alert("❌ FAIL: dict['key'] — got {@nameAltStr}, expected 'Alice'")
}

// setValue round-trip
const updated = setValue(@dict, "name", "Bob")
const newName = getValue(updated, "name")
if newName != "Bob" {
    alert("❌ FAIL: setValue — got {newName}, expected 'Bob'")
}

// getDictionary from raw JSON string
@json = '{"key": "hello", "num": 7}'
const parsed = getDictionary(@json)
const parsedVal = getValue(parsed, "key")
if parsedVal != "hello" {
    alert("❌ FAIL: getDictionary/getValue — got {parsedVal}, expected 'hello'")
}

// getKeys returns :array (has value check works for any type)
const keys = getKeys(@dict)
if !keys {
    alert("❌ FAIL: getKeys — returned no value")
}

// getValues returns :array
const vals = getValues(@dict)
if !vals {
    alert("❌ FAIL: getValues — returned no value")
}

show("✅ All tests passed")
