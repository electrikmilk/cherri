// Specified dates: fully assertable relational facts using variable-to-variable comparisons
@past = date("January 1, 2020")
@future = date("December 31, 2030")
@same = date("January 1, 2020")

@r = "wrong"
if @past < @future { @r = "right" }
if @r != "right" { mustOutput("❌ FAIL: date < (past < future)", "❌ FAIL: date < (past < future)") }

@r = "wrong"
if @future > @past { @r = "right" }
if @r != "right" { mustOutput("❌ FAIL: date > (future > past)", "❌ FAIL: date > (future > past)") }

@r = "wrong"
if @past == @same { @r = "right" }
if @r != "right" { mustOutput("❌ FAIL: date == (same date)", "❌ FAIL: date == (same date)") }

@r = "wrong"
if @past != @future { @r = "right" }
if @r != "right" { mustOutput("❌ FAIL: date !=", "❌ FAIL: date !=") }

// between: @past is between an earlier and later date
@earlier = date("January 1, 2000")
@later = date("December 31, 2025")
@r = "wrong"
if @past <> @earlier @later { @r = "right" }
if @r != "right" { mustOutput("❌ FAIL: date between", "❌ FAIL: date between") }

// Dynamic date: compile-only coverage (value varies at runtime)
@today = currentDate()
@formatted = formatDate(@today)
@adjusted = adjustDate(@today, "Add", qty(5, "days"))
if @adjusted > @today {} else {}
if @adjusted < @today {} else {}

// isToday and qty comparisons (from conditionals-date.cherri)
if CurrentDate isToday {}
if CurrentDate > qty(3, "hr") {} else {}
if CurrentDate < qty(5, "min") {} else {}
if CurrentDate == @today {}
if CurrentDate > @today {}
if CurrentDate <> @today @adjusted {}

// Holiday date (compile-only)
@holiday = getHolidayDate("Christmas Day")
if @holiday == @today {} else {}

show("✅ All tests passed")
