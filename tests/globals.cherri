// Device global: always has a value on any device
if !Device {
    mustOutput("❌ FAIL: Device global — no value", "❌ FAIL: Device global — no value")
}

// CurrentDate global: always has a value
if !CurrentDate {
    mustOutput("❌ FAIL: CurrentDate global — no value", "❌ FAIL: CurrentDate global — no value")
}

// compile-only coverage for interactive/context-dependent globals
@input = ShortcutInput
@clipboard = Clipboard
@shortcutInput = "{ShortcutInput}"

show("✅ All tests passed")
