@items = list("alpha", "beta", "gamma", "delta")

// getFirstItem
const first = getFirstItem(@items)
if first.text != "alpha" {
    mustOutput("❌ FAIL: getFirstItem — got {first}, expected 'alpha'", "❌ FAIL: getFirstItem — got {first}, expected 'alpha'")
}

// getLastItem
const last = getLastItem(@items)
if last.text != "delta" {
    mustOutput("❌ FAIL: getLastItem — got {last}, expected 'delta'", "❌ FAIL: getLastItem — got {last}, expected 'delta'")
}

// getListItem: Shortcuts indexes from 1
const second = getListItem(@items, 2)
if second.text != "beta" {
    mustOutput("❌ FAIL: getListItem — got {second}, expected 'beta'", "❌ FAIL: getListItem — got {second}, expected 'beta'")
}

// getListItems: items 2–3 → has value (output is a list, not directly comparable)
const slice = getListItems(@items, 2, 3)
if !slice {
    mustOutput("❌ FAIL: getListItems — returned no value", "❌ FAIL: getListItems — returned no value")
}

// getRandomItem: non-deterministic, only assert has value
const random = getRandomItem(@items)
if !random {
    mustOutput("❌ FAIL: getRandomItem — returned no value", "❌ FAIL: getRandomItem — returned no value")
}

// += append: verify the appended item becomes the last
@mutable = ["x", "y"]
@mutable += "z"
const appended = getLastItem(@mutable)
if appended.text != "z" {
    mustOutput("❌ FAIL: += append — got {appended}, expected 'z'", "❌ FAIL: += append — got {appended}, expected 'z'")
}

// += append multiple times, verify order is preserved
@mutable += "w"
const afterSecond = getLastItem(@mutable)
if afterSecond.text != "w" {
    mustOutput("❌ FAIL: += second append — got {afterSecond}, expected 'w'", "❌ FAIL: += second append — got {afterSecond}, expected 'w'")
}
const stillZ = getListItem(@mutable, 3)
if stillZ.text != "z" {
    mustOutput("❌ FAIL: prior item after append — got {stillZ}, expected 'z'", "❌ FAIL: prior item after append — got {stillZ}, expected 'z'")
}

show("✅ All tests passed")
