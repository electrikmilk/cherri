// Tests color() and qty() as explicit action arguments

// qty() — time-duration type, used by startTimer in actions/calendar.cherri
startTimer(qty(5, "min"))

// color() — colour type, used by makeQRCode in actions/documents.cherri
makeQRCode("https://cherrilang.org")
makeQRCode("https://cherrilang.org", "High", color(0.0,0.0,0.0,1.0), color(2.0,2.0,2.0,1.0))
