// copy/paste: compiler feature that inlines the block at each paste site
@testVal = "cherri-test"
copy carbon {
    setClipboard(@testVal)
}

paste carbon

// clipboard round-trip: assert the pasted setClipboard took effect
const clip = getClipboard()
@clipStr = "{clip}"
if @clipStr != "cherri-test" {
    alert("❌ FAIL: clipboard round-trip — got {@clipStr}, expected 'cherri-test'")
}

show("✅ All tests passed")
