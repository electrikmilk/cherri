// arithmetic operators
const sum = 5 + 3
if sum != 8 {
    mustOutput("❌ FAIL: addition — got {sum}, expected '8'", "❌ FAIL: addition — got {sum}, expected '8'")
}

const diff = 10 - 4
if diff != 6 {
    mustOutput("❌ FAIL: subtraction — got {diff}, expected '6'", "❌ FAIL: subtraction — got {diff}, expected '6'")
}

const product = 3 * 4
if product != 12 {
    mustOutput("❌ FAIL: multiplication — got {product}, expected '12'", "❌ FAIL: multiplication — got {product}, expected '12'")
}

const quotient = 10 / 2
if quotient != 5 {
    mustOutput("❌ FAIL: division — got {quotient}, expected '5'", "❌ FAIL: division — got {quotient}, expected '5'")
}

// modulus (previously calc.cherri)
const modulus = 10 % 3
if modulus != 1 {
    mustOutput("❌ FAIL: modulus — got {modulus}, expected '1'", "❌ FAIL: modulus — got {modulus}, expected '1'")
}

// randomNumber: assert within range only (value is non-deterministic)
@rand = randomNumber(1, 10)
if @rand < 1 {
    mustOutput("❌ FAIL: randomNumber min — got {@rand}, expected >= 1", "❌ FAIL: randomNumber min — got {@rand}, expected >= 1")
}
if @rand > 10 {
    mustOutput("❌ FAIL: randomNumber max — got {@rand}, expected <= 10", "❌ FAIL: randomNumber max — got {@rand}, expected <= 10")
}

show("✅ All tests passed")
