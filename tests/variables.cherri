// mutation operators
@x = 5
@x += 3
if @x != 8 {
    mustOutput("❌ FAIL: += — got {@x}, expected '8'", "❌ FAIL: += — got {@x}, expected '8'")
}

@x = 10
@x -= 4
if @x != 6 {
    mustOutput("❌ FAIL: -= — got {@x}, expected '6'", "❌ FAIL: -= — got {@x}, expected '6'")
}

@x = 5
@x *= 3
if @x != 15 {
    mustOutput("❌ FAIL: *= — got {@x}, expected '15'", "❌ FAIL: *= — got {@x}, expected '15'")
}

@x = 10
@x /= 2
if @x != 5 {
    mustOutput("❌ FAIL: /= — got {@x}, expected '5'", "❌ FAIL: /= — got {@x}, expected '5'")
}

// string interpolation
@a = "Hello"
@b = "{@a} World"
if @b != "Hello World" {
    mustOutput("❌ FAIL: interpolation — got {@b}, expected 'Hello World'", "❌ FAIL: interpolation — got {@b}, expected 'Hello World'")
}

// const (magic variable) in interpolation
const immutable = 42
@text = "value is {immutable}"
if @text != "value is 42" {
    mustOutput("❌ FAIL: const interpolation — got {@text}, expected 'value is 42'", "❌ FAIL: const interpolation — got {@text}, expected 'value is 42'")
}

// type declarations compile (no assertion — types are a compiler concern)
@typed: text
@numTyped: number
@arrTyped: array
@dictTyped: dictionary
@boolTyped: bool

// type assignment via literal
@n = 7
@f = 1.5
@flag = true
@items = ["a", "b", "c"]
@dict = {"key": "val"}

// number used in string context
@asText = "{@n}"
if @asText != "7" {
    mustOutput("❌ FAIL: number to string — got {@asText}, expected '7'", "❌ FAIL: number to string — got {@asText}, expected '7'")
}

show("✅ All tests passed")
