@intVar = 3
@intVar2 = 7
@testVar = "test"

repeat i for 6 {
    @intVar2 = 5
    if @intVar == @intVar2 {
        @testVar = "test2"
    }
}

@listVar = list("item 1","item 2","item 3")
for item in @listVar {
    alert("{RepeatIndex}", @item)
}

repeat i for 20 {
	const divThree = @i % 3
	const divFive = @i % 5
	if divThree == 0 && divFive == 0 {
		alert("FizzBuzz")
    }
	if divThree == 0 && divFive != 0 {
		alert("Fizz")
    }
	if divFive == 0 && divThree != 0 {
		alert("Buzz")
    }
	if divThree != 0 && divFive != 0 {
		alert("{@i}")
    }
}
